# Spotify API credentials — create an app at https://developer.spotify.com/dashboard
SPOTIPY_CLIENT_ID=your_client_id
SPOTIPY_CLIENT_SECRET=your_client_secret
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Optional: Override Arduino port (auto-detected if not set)
# ARDUINO_PORT=/dev/cu.usbmodem14201

# Optional: Poll interval in seconds for Spotify LED (default: 3)
# POLL_INTERVAL=3

# Knob mixer: directory containing audio files (default: ./songs)
# SONGS_DIR=./songs
